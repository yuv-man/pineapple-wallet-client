{
  "name": "pineapple-wallet-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "build:static": "CAPACITOR_STATIC_EXPORT=true next build",
    "build:mobile": "npm run build:static && npx cap sync",
    "prestart:static": "node -e \"const fs=require('fs');const p=require('path');if(!fs.existsSync(p.join('out','index.html'))){console.log('No out/ — run: npm run build:static');process.exit(1)}\"",
    "start": "next start -p 3003",
    "start:static": "npm run prestart:static && serve out -p 3003",
    "lint": "next lint",
    "build:android": "npm run build:static && npx cap sync android",
    "build:ios": "npm run build:static && npx cap sync ios",
    "android": "npx cap open android",
    "ios": "npx cap open ios",
    "android:dev": "CAPACITOR_LIVE_RELOAD=true npx cap run android",
    "ios:dev": "CAPACITOR_LIVE_RELOAD=true npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@hookform/resolvers": "^3.3.4",
    "axios": "^1.6.5",
    "clsx": "^2.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.309.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "recharts": "^2.10.4",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "postcss": "^8.4.33",
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
